  "keyFeatures": [
    "Secure authentication with OTP verification",
    "Dynamic social feed with images, videos, and stories",
    "Real-time messaging with Socket.IO and FCM fallback",
    "TikTok-style reels with ExoPlayer",
    "Custom camera implementation with CameraX",
    "Offline support with Room Database",
    "Social interactions: likes, comments, shares, follow/unfollow"
  ],
  "publicApiSurface": [
    "AuthManager - Authentication APIs",
    "PostsManager - Post CRUD operations",
    "MessageManager - Real-time messaging",
    "ProfileManager - User profile management",
    "StoriesManager - Stories functionality",
    "LikeManager - Post interactions",
    "CommentsManager - Comment system",
    "FollowManager - Follow/unfollow system",
    "SearchManager - User and content search"
  ]
